{
    "name": "saimaz/laravel-prometheus",
    "description": "Professional Prometheus metrics integration for Laravel applications",
    "keywords": ["laravel", "prometheus", "metrics", "monitoring", "observability"],
    "homepage": "https://github.com/saimaz/laravel-prometheus",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Ninebit",
            "email": "simonas.serlinskas@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/saimaz/laravel-prometheus/issues",
        "source": "https://github.com/saimaz/laravel-prometheus"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "promphp/prometheus_client_php": "^2.6"
    },
    "require-dev": {
        "laravel/horizon": "^5.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Ninebit\\LaravelPrometheus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ninebit\\LaravelPrometheus\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ninebit\\LaravelPrometheus\\LaravelPrometheusServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
